# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# --- PASTAS DE INFRAESTRUTURA (EXCLUSIVAS DA OCI) ---
# Adicionamos estas pastas para que o Git as ignore e não as remova no servidor
maintenance/
nginx/
infra/
scripts/

# --- DEPENDÊNCIAS ---
node_modules/
**/node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --- BUILDS E CACHE ---
/.next/
/out/
/build/
/dist/
*.tsbuildinfo
next-env.d.ts
/coverage

# --- VARIÁVEIS DE AMBIENTE (SENSÍVEL) ---
.env
.env.local
.env.production
.env.development
.env*.local

# --- MISC / DEBUG ---
.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.vercel

# --- DATABASE (Se usar SQLite local para testes) ---
*.db
*.db-journal